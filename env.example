# Copy to `.env` and fill in. Never commit your real .env.

# The mock API base URL (started by `make serve`).
API_BASE_URL=http://127.0.0.1:8099

# Scoped tokens the mock API checks. The defaults match the server's dev
# defaults, so you can leave them as-is for local work.
#   READ_TOKEN  - can read /inbox only
#   WRITE_TOKEN - can read AND write (mail + CRM)
# Think about which parts of your skill should ever hold the write token.
READ_TOKEN=read-token-dev
WRITE_TOKEN=write-token-dev

# Bring your own LLM key — Anthropic, OpenAI, or any provider you prefer.
# Add whatever variable(s) your chosen SDK expects. Examples:
#   ANTHROPIC_API_KEY=sk-ant-...
#   OPENAI_API_KEY=sk-...
# (requirements.txt ships the Anthropic SDK as a convenience; swap freely.)
